# Optional: get a free key at https://console.groq.com/keys
# If left unset, the system automatically uses a deterministic rule-based
# NL->SQL engine instead, so it still runs and answers all sample queries
# with zero cost and zero internet dependency.
GROQ_API_KEY=

# Optional: override the Groq model (default shown below)
GROQ_MODEL=llama-3.1-8b-instant

# Optional: path to the dataset CSV (default: ./support_tickets.csv)
TICKETS_CSV=support_tickets.csv
